{
  "name": "bazaar-lens",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "uvicorn api.index:app --reload --host 0.0.0.0 --port 8001",
